# Copy to .env for local overrides used by docker compose.
# This file is safe to commit; do not commit real secrets in .env.

METROOPS_RUNTIME_ENV=development
FLASK_DEBUG=0
DISABLE_TLS_ENFORCEMENT=0
SESSION_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=Lax
METROOPS_DB_PATH=/app/data/metroops.db
METROOPS_KEY_PATH=/app/data/secret.key

# Optional in development: leave blank to auto-generate at container startup.
# Required in production-like runtime (production/staging).
METROOPS_GATEWAY_TOKEN=
